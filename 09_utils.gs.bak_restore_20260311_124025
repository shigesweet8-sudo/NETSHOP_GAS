function showAlert_(title, message) {
  SpreadsheetApp.getUi().alert(title, message, SpreadsheetApp.getUi().ButtonSet.OK);
}

function zeroPad_(n) {
  return n < 10 ? '0' + n : String(n);
}

function formatJPY_(n) {
  return '¥' + Math.round(n).toLocaleString('ja-JP');
}

function formatPercent_(ratio, digits) {
  var d = digits !== undefined ? digits : 1;
  return (ratio * 100).toFixed(d) + '%';
}

function generateId_() {
  var now    = new Date();
  var prefix = 'M';
  var date   = Utilities.formatDate(now, 'Asia/Tokyo', 'yyyyMMdd');
  var time   = Utilities.formatDate(now, 'Asia/Tokyo', 'HHmmssSSS');
  return prefix + '-' + date + '-' + time;
}

function formatDate_(d) {
  if (!d) return '';
  var date = d instanceof Date ? d : new Date(d);
  if (isNaN(date.getTime())) return '';
  return Utilities.formatDate(date, 'Asia/Tokyo', 'yyyy/MM/dd');
}

function getMonthStart_() {
  var d = new Date();
  return new Date(d.getFullYear(), d.getMonth(), 1);
}

function getMonthEnd_() {
  var d = new Date();
  return new Date(d.getFullYear(), d.getMonth() + 1, 0);
}

function sum_(arr) {
  return arr.reduce(function(a, b) { return a + (parseFloat(b) || 0); }, 0);
}

function groupBy_(arr, key) {
  return arr.reduce(function(acc, item) {
    var k = item[key];
    if (!acc[k]) acc[k] = [];
    acc[k].push(item);
    return acc;
  }, {});
}

function getLastDataRow_(sheet, checkCol) {
  var col     = checkCol || 1;
  var lastRow = sheet.getLastRow();
  var data    = sheet.getRange(1, col, lastRow, 1).getValues();
  for (var i = lastRow - 1; i >= 0; i--) {
    if (data[i][0] !== '') return i + 1;
  }
  return 0;
}

function setNamedRange_(ss, name, range) {
  try {
    ss.setNamedRange(name, range);
  } catch (e) {
    var existing = ss.getRangeByName(name);
    if (existing) ss.removeNamedRange(name);
    ss.setNamedRange(name, range);
  }
}

function log_(msg) {
  var ts = Utilities.formatDate(new Date(), 'Asia/Tokyo', 'HH:mm:ss');
  Logger.log('[' + ts + '] ' + msg);
}

function isValidDate_(val) {
  if (!val) return false;
  var d = val instanceof Date ? val : new Date(val);
  return !isNaN(d.getTime());
}

function isPositiveNumber_(val) {
  var n = parseFloat(val);
  return !isNaN(n) && n > 0;
}

function normalizeMonthString_(monthStr) {
  if (!monthStr) return '';
  
  monthStr = String(monthStr).trim();

  const m = monthStr.match(/^(\d{4})[-\/]?(\d{1,2})$/);
  if (!m) return monthStr;

  const year = m[1];
  const month = ('0' + m[2]).slice(-2);

  return `${year}-${month}`;
}

function getThisMonthString_() {
  const d = new Date();
  const y = d.getFullYear();
  const m = ('0' + (d.getMonth() + 1)).slice(-2);
  return `${y}-${m}`;
}

function parseMonthRange_(monthStr) {
  const parts = monthStr.split('-');
  const year = Number(parts[0]);
  const month = Number(parts[1]) - 1;

  const start = new Date(year, month, 1);
  const end = new Date(year, month + 1, 1);

  return { start, end };
}

function sum_(rows, key) {
  return rows.reduce((total, r) => total + (Number(r[key]) || 0), 0);
}

function toNumber(v) {
  const n = Number(v);
  return isNaN(n) ? 0 : n;
}

function tryParseDate_(v) {
  if (!v) return null;
  if (v instanceof Date) return v;

  const d = new Date(v);
  return isNaN(d.getTime()) ? null : d;
}

function columnToLetter_(column) {
  var letter = '';
  var temp = column;
  while (temp > 0) {
    var mod = (temp - 1) % 26;
    letter = String.fromCharCode(65 + mod) + letter;
    temp = Math.floor((temp - mod) / 26);
  }
  return letter;
}

function isManagedHighlightRuleV2_(rule, firstDataRow, dataStartCol, lastCol) {
  var ranges = rule.getRanges();
  if (!ranges || !ranges.length) return false;

  var touchesManagedRange = ranges.some(function(range) {
    var startCol = range.getColumn();
    var endCol = startCol + range.getNumColumns() - 1;
    var endRow = range.getRow() + range.getNumRows() - 1;
    return endRow >= firstDataRow && !(endCol < dataStartCol || startCol > lastCol);
  });
  if (!touchesManagedRange) return false;

  var condition = rule.getBooleanCondition && rule.getBooleanCondition();
  if (!condition) return false;

  var criteriaType = condition.getCriteriaType && condition.getCriteriaType();
  var criteriaValues = condition.getCriteriaValues && condition.getCriteriaValues();
  if (String(criteriaType) !== 'CUSTOM_FORMULA' || !criteriaValues || !criteriaValues.length) {
    return false;
  }

  var formula = String(criteriaValues[0] || '');
  if (!formula) return false;

  return formula.indexOf('$A' + firstDataRow) !== -1 ||
    formula.indexOf(CONFIG.STATUS.REGISTER) !== -1 ||
    formula.indexOf(CONFIG.STATUS.LISTING) !== -1 ||
    formula.indexOf(CONFIG.STATUS.NEGOTIATING) !== -1 ||
    formula.indexOf(CONFIG.STATUS.PAID) !== -1 ||
    formula.indexOf(CONFIG.STATUS.PREPARING) !== -1 ||
    formula.indexOf(CONFIG.STATUS.SHIPPED) !== -1 ||
    formula.indexOf(CONFIG.STATUS.COMPLETED) !== -1 ||
    formula.indexOf(CONFIG.STATUS.CANCEL) !== -1;
}

function applyHighlightRules_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(CONFIG.SHEET_NAME);
  if (!sheet) {
    throw new Error('Target sheet not found: ' + CONFIG.SHEET_NAME);
  }

  var firstDataRow = 2;
  var statusCol = CONFIG.COLS.STATUS;
  var dateBaseCol = 4;
  var listingDateCol = 5;
  var maxRows = Math.max(sheet.getMaxRows() - 1, 1);
  var lastCol = sheet.getLastColumn();
  var dataRange = sheet.getRange(firstDataRow, dateBaseCol, maxRows, lastCol - dateBaseCol + 1);
  var listingDateRange = sheet.getRange(firstDataRow, listingDateCol, maxRows, 1);
  var statusRef = '$' + columnToLetter_(statusCol) + firstDataRow;
  var keptRules = sheet.getConditionalFormatRules().filter(function(rule) {
    return !isManagedHighlightRuleV2_(rule, firstDataRow, dateBaseCol, lastCol);
  });
  var newRules = [];

  function pushStatusRule(status, background, fontColor) {
    var builder = SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied('=' + statusRef + '="' + status + '"')
      .setBackground(background)
      .setRanges([dataRange]);

    if (fontColor) {
      builder.setFontColor(fontColor);
    }

    newRules.push(builder.build());
  }

  pushStatusRule(CONFIG.STATUS.REGISTER, '#fff2cc');
  pushStatusRule(CONFIG.STATUS.LISTING, '#e8f0fe');
  pushStatusRule(CONFIG.STATUS.NEGOTIATING, '#fce5cd');
  pushStatusRule(CONFIG.STATUS.PAID, '#d9ead3');
  pushStatusRule(CONFIG.STATUS.PREPARING, '#d0e0e3');
  pushStatusRule(CONFIG.STATUS.SHIPPED, '#cfe2f3');
  pushStatusRule(CONFIG.STATUS.COMPLETED, '#eeeeee', '#666666');
  pushStatusRule(CONFIG.STATUS.CANCEL, '#f4cccc', '#999999');

  newRules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied('=' + statusRef + '="' + CONFIG.STATUS.REGISTER + '"')
      .setBackground('#fff2cc')
      .setRanges([listingDateRange])
      .build()
  );

  sheet.setConditionalFormatRules(keptRules.concat(newRules));
}

function runApplyHighlightRules() {
  applyHighlightRules_();
}
